# ── Auth ──────────────────────────────────────────────────────────────────────
APP_PASSWORD=troque-esta-senha
JWT_SECRET=gere-um-segredo-longo-aleatorio

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_NAME=chatia
DB_USER=chatia
DB_PASSWORD=chatia
DB_HOST=postgres   # "postgres" dentro do Docker; "localhost" rodando local sem Docker
DB_PORT=5432

# ── Ollama ────────────────────────────────────────────────────────────────────
# Windows + Docker Desktop: use host.docker.internal para acessar Ollama do host
OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_API_KEY=   # Apenas para Ollama Cloud (ollama.com)

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# Claude via assinatura (opcional) — gere com: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=...

# ── Google Gemini ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=...

# ── Groq ──────────────────────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── OpenRouter ────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...

# ── Busca web ─────────────────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...
# FIRECRAWL_API_KEY=fc-...

# ── RAG ───────────────────────────────────────────────────────────────────────
# RAG_THRESHOLD_CHARS=8000   # acima disso usa RAG vetorial em vez de truncamento
# RAG_TOP_K=5
